{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
    "manifestVersion": "1.24",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Noam Hanimov",
        "websiteUrl": "https://github.com/noamh98/workshop-design-system",
        "privacyUrl": "https://github.com/noamh98/workshop-design-system",
        "termsOfUseUrl": "https://github.com/noamh98/workshop-design-system"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "Workshop Deck Builder",
        "full": "Workshop Deck Builder Agent"
    },
    "description": {
        "short": "Builds executive HTML presentations in the Workshop Design System style.",
        "full": "Workshop Deck Builder creates standalone executive presentation HTML files in the Workshop Design System style (hand-sketched consultant-notebook aesthetic, Hebrew RTL, six-ink semantic convention) from a topic or raw material, then commits the result to the workshop-design-system GitHub repository."
    },
    "accentColor": "#F5F0E6",
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": []
}
